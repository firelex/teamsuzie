{
  "name": "@teamsuzie/pptx-agent",
  "version": "0.1.0",
  "description": "LLM-powered presentation builder using PptxGenJS for Team Suzie",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
