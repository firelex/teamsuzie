MARKITDOWN_AGENT_HOST=0.0.0.0
MARKITDOWN_AGENT_PORT=3013

# Per-file upload cap (bytes). Default 50MB.
# MARKITDOWN_AGENT_MAX_UPLOAD_BYTES=52428800

# Path to a styled .docx; pandoc --reference-doc inherits its styles when exporting.
# Set this for firm/template fidelity on DOCX exports.
# MARKITDOWN_AGENT_REFERENCE_DOCX=/path/to/firm-template.docx

# If set, uvicorn reloads on code changes.
# MARKITDOWN_AGENT_RELOAD=1
