NODE_ENV=development

ADMIN_PORT=3008
ADMIN_PUBLIC_URL=http://localhost:3008
ADMIN_ALLOWED_ORIGIN=http://localhost:5175
ADMIN_TITLE=Team Suzie Admin

# JSON array of OpenClaw-compatible agents used by the Chat page.
# Each agent should include: id, name, baseUrl. Optional: apiKey, openclawAgentId.
# Example:
# CHAT_AGENTS=[{"id":"suzie","name":"Suzie","baseUrl":"http://localhost:18789","apiKey":"your-token","openclawAgentId":"main"}]
CHAT_AGENTS=[]

# Shared infrastructure (use `pnpm docker:up` from the repo root to bring these up locally).
POSTGRES_URI=postgres://teamsuzie:teamsuzie@localhost:5432/teamsuzie
REDIS_URI=redis://localhost:6379/0
REDIS_KEY_PREFIX=admin

# Session cookie.
COOKIE_NAME=admin.sid
COOKIE_SECRET=dev-only-admin-secret-change-me
COOKIE_MAXAGE=2678400000

# CSRF token cookie.
CSRF_COOKIE_NAME=DEV-CSRF-TOKEN

# Master secret used to encrypt config_value.value_encrypted. Falls back to
# COOKIE_SECRET in dev; must be set explicitly in production.
CONFIG_SECRET=dev-only-config-secret-change-me

# Dev-only seed user shown on the login page.
DEMO_EMAIL=demo@example.com
DEMO_PASSWORD=demo12345
DEMO_NAME=Demo User

# Admin user created on first boot (dev only).
SEED_EMAIL=admin@example.com
SEED_PASSWORD=admin12345
SEED_NAME=Admin
