{
  "name": "@teamsuzie/admin",
  "version": "0.1.0",
  "description": "OSS admin control plane: agents, skills, approvals, artifacts, tokens, config, activity",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "cd ../../../packages/shared-auth && npx tsc",
    "dev": "tsx watch src/bootstrap.ts & pnpm --filter @teamsuzie/admin-client dev & wait",
    "build": "tsc",
    "start": "node dist/bootstrap.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@teamsuzie/shared-auth": "workspace:*",
    "connect-redis": "^8.0.1",
    "cors": "^2.8.5",
    "csrf": "^3.1.0",
    "dotenv": "^16.6.0",
    "express": "^5.1.0",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.7",
    "sequelize-typescript": "^2.1.6",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.1",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
