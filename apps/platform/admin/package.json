{
  "name": "@teamsuzie/admin",
  "version": "0.1.0",
  "description": "Minimal OSS admin app with OpenClaw-compatible chat",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts & pnpm --filter @teamsuzie/admin-client dev & wait",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.0",
    "express": "^5.1.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
