{
  "name": "@teamsuzie/auth",
  "version": "0.1.0",
  "description": "Multi-tenant authentication service for Team Suzie",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "cd ../../packages/shared-auth && npx tsc",
    "dev": "tsx watch src/bootstrap.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@teamsuzie/shared-auth": "workspace:*",
    "bcryptjs": "^3.0.3",
    "connect-redis": "^8.0.1",
    "cors": "^2.8.6",
    "csrf": "^3.1.0",
    "dotenv": "^16.6.0",
    "express": "^5.1.0",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.7",
    "sequelize-typescript": "^2.1.6",
    "umzug": "^3.8.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.1",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
