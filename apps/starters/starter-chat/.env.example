STARTER_CHAT_PORT=16311
STARTER_CHAT_PUBLIC_URL=http://localhost:16311
STARTER_CHAT_ALLOWED_ORIGIN=http://localhost:17276
STARTER_CHAT_TITLE=Starter Chat
STARTER_CHAT_AGENT_NAME=Suzie
STARTER_CHAT_AGENT_DESCRIPTION=OpenAI-compatible assistant
STARTER_CHAT_AGENT_BASE_URL=http://localhost:4000
STARTER_CHAT_MODEL=openai/gpt-4.1-mini
STARTER_CHAT_CLIENT_PORT=17276
# Optional
# STARTER_CHAT_AGENT_API_KEY=

# Tool use — built-in vector_search tool calls vector-db
STARTER_CHAT_VECTOR_DB_BASE_URL=http://localhost:3006
# STARTER_CHAT_VECTOR_DB_API_KEY=
# Cap on tool-use loop iterations (model -> tool -> model -> ...)
STARTER_CHAT_TOOL_MAX_ITERATIONS=6

# Skills bridge — installed skill markdown is loaded into the system prompt at
# server start, and the http_request tool (allow-listed) lets the model call
# the URLs the skills describe.
#
# Local templates directory (set to load skills bundled in @teamsuzie/skills):
# STARTER_CHAT_SKILLS_DIR=../../packages/skills/templates
#
# Or point at a remote skill catalog (see apps/examples/skill-catalog-host):
# STARTER_CHAT_SKILL_CATALOG_URL=http://localhost:3021
# STARTER_CHAT_SKILL_CATALOG_TOKEN=
#
# Optional: limit which skills install. Empty = install all discovered.
# STARTER_CHAT_SKILLS_ALLOW=spreadsheets,presentations
#
# {{TOKEN}} substitutions for skill markdown. Use the STARTER_CHAT_SKILL_VAR_
# prefix; the rest becomes the placeholder name. URL-shaped values automatically
# extend the http_request allow-list.
# STARTER_CHAT_SKILL_VAR_XLSX_AGENT_URL=http://localhost:3012
# STARTER_CHAT_SKILL_VAR_PPTX_AGENT_URL=http://localhost:3009
# STARTER_CHAT_SKILL_VAR_AGENT_API_KEY=
# STARTER_CHAT_SKILL_VAR_AGENT_SLUG=starter-chat
#
# Extra hosts the http_request tool may call (comma-separated host:port).
# Skill render-context URL hosts are auto-included; only set this for hosts
# that aren't referenced from a skill placeholder.
# STARTER_CHAT_HTTP_ALLOWED_HOSTS=internal-api.example.com

# MCP — connect to external Model Context Protocol servers and expose their
# tools to the agent. Point at a JSON file using Claude Desktop's mcpServers
# shape. stdio servers use `command` + `args`; remote (Streamable HTTP)
# servers use `url`. Each MCP tool surfaces as `<server-name>__<tool-name>`.
# STARTER_CHAT_MCP_CONFIG=./mcp.json
