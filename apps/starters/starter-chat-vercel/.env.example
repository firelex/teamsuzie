# Public-facing UI label (no secret)
NEXT_PUBLIC_APP_TITLE=Starter Chat (Vercel)
NEXT_PUBLIC_AGENT_NAME=Suzie

# Model — any OpenAI-compatible base URL.
AGENT_BASE_URL=http://localhost:4000
AGENT_MODEL=openai/gpt-4.1-mini
# AGENT_API_KEY=

# Tool: vector_search target
VECTOR_DB_BASE_URL=http://localhost:3006
# VECTOR_DB_API_KEY=

# Cap on tool-use loop iterations (model -> tool -> model -> ...)
TOOL_MAX_ITERATIONS=6

# http_request allow-list. Skill render-context URL hosts auto-extend this.
# Example: HTTP_ALLOWED_HOSTS=internal-api.example.com
# HTTP_ALLOWED_HOSTS=

# Skills bridge — the Vercel starter only supports REMOTE catalogs.
# (Filesystem-based skills are intentionally NOT supported on Vercel —
# see README "What this starter does NOT support".)
# SKILL_CATALOG_URL=https://your-skill-catalog.example.com
# SKILL_CATALOG_TOKEN=
# SKILLS_ALLOW=spreadsheets,presentations
# SKILL_VAR_XLSX_AGENT_URL=https://your-xlsx-agent.example.com
# SKILL_VAR_PPTX_AGENT_URL=https://your-pptx-agent.example.com
# SKILL_VAR_AGENT_API_KEY=
# SKILL_VAR_AGENT_SLUG=starter-chat-vercel

# MCP — only HTTP-transport (Streamable HTTP) servers work on Vercel.
# Stdio MCP servers are intentionally NOT supported (no subprocesses in
# serverless). Inline JSON; same `mcpServers` shape as Claude Desktop.
# MCP_CONFIG_JSON={"mcpServers":{"internal-api":{"url":"https://mcp.internal/mcp","headers":{"Authorization":"Bearer xxx"}}}}
