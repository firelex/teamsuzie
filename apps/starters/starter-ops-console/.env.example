# Backend ports and URLs
STARTER_OPS_PORT=18311
STARTER_OPS_PUBLIC_URL=http://localhost:18311
STARTER_OPS_ALLOWED_ORIGIN=http://localhost:18276
STARTER_OPS_TITLE=Team Suzie
STARTER_OPS_CLIENT_PORT=18276

NODE_ENV=development

# Approval queue
# Destructive actions (delete, bulk delete, send/publish/dispatch) route through
# @teamsuzie/approvals by default. Set to false for local/simple use to skip the queue.
STARTER_OPS_APPROVALS_ENABLED=true

# Postgres (required for real auth + contacts). Run `pnpm docker:up` from the repo
# root to start a local postgres/redis matching these defaults.
POSTGRES_URI=postgres://teamsuzie:teamsuzie@localhost:5432/teamsuzie

# Redis (session store)
REDIS_URI=redis://localhost:6379/0
REDIS_KEY_PREFIX=starter-ops-console

# Session cookie
COOKIE_NAME=starter-ops.sid
COOKIE_SECRET=dev-only-ops-console-secret
CSRF_COOKIE_NAME=DEV-CSRF-TOKEN

# Seed users (used by `pnpm --filter @teamsuzie/starter-ops-console seed`).
# The demo credentials are shown on the login page in development for easy onboarding.
SEED_EMAIL=admin@example.com
SEED_PASSWORD=admin12345
SEED_NAME=Ops Admin

DEMO_EMAIL=demo@example.com
DEMO_PASSWORD=demo12345
DEMO_NAME=Demo User

# Agent drawer (optional)
STARTER_OPS_AGENT_BASE_URL=http://localhost:4000
STARTER_OPS_AGENT_API_KEY=
STARTER_OPS_AGENT_NAME=Suzie
STARTER_OPS_MODEL=openai/gpt-4.1-mini
